on:
  push:
    branches: [ "main" ]

jobs:
  build-test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Install Dependencies
        run: npm install

      - name: Run Tests
        run: npm test

      - name: Build Docker Image
        run: docker build -t myapp:${{ github.sha }} .

      - name: Scan Image
        run: trivy image myapp:${{ github.sha }}    #sonarQube also we can use it.

      - name: Push Image
        run: docker push myrepo/myapp:${{ github.sha }}

  deploy-dev:
    needs: build-test
    runs-on: ubuntu-latest
    steps:
      - name: Deploy to Dev
        run: kubectl apply -f k8s/

  deploy-prod:
    needs: deploy-dev
    runs-on: ubuntu-latest
    environment: production   # Approval required
    steps:
      - name: Deploy to Prod
        run: kubectl apply -f k8s/
